# Non-sensitive config only — no secrets in this file
# In dev, Vite proxies /api to VITE_API_URL, so relative paths work.
# In production (Docker/nginx), the nginx config proxies /api to core-api.

# Core API base URL — used when NOT running behind Vite dev server proxy
# Leave empty to use relative /api paths (works with Vite proxy and nginx)
VITE_API_URL=
