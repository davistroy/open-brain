    "test": "vitest run --passWithNoTests",
    "lint": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@bull-board/api": "^6.20.3",
    "@bull-board/hono": "^6.20.3",
    "@hono/node-server": "^1.19.11",
    "@hono/zod-validator": "^0.7.6",
    "@open-brain/shared": "workspace:*",
    "@types/pg": "^8.18.0",
    "bullmq": "^5.0.0",
    "drizzle-orm": "^0.45.1",
    "hono": "^4.12.5",
    "ioredis": "^5.10.0",
    "openai": "^4.98.0",
    "pg": "^8.20.0",
    "pino": "^10.3.1",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/ioredis": "^5.0.0",
    "@types/node": "^25.3.5",
    "@vitest/coverage-v8": "^1.6.0",
    "tsup": "^8.0.0",
    "tsx": "^4.7.0",
    "typescript": "^5.4.0",
    "vitest": "^1.6.0"
  }
}
