# ============================================================
# Node.js / TypeScript
# ============================================================
node_modules/
*.tsbuildinfo
.turbo/

# Build output — dist/ is NOT committed; Dockerfile has a builder stage that
# runs pnpm build internally. Local dist/ directories are build artifacts only.
dist/

# ============================================================
# Secrets and environment
# ============================================================
# All secrets are in Bitwarden — never in .env files
.env
.env.local
.env.*.local
.env.secrets
*.pem
*.key

# ============================================================
# Test and coverage artifacts
# ============================================================
coverage/
htmlcov/
.coverage
.coverage.*
.pytest_cache/
*.cover

# ============================================================
# OS artifacts
# ============================================================
.DS_Store
Thumbs.db
desktop.ini

# ============================================================
# Editor / IDE
# ============================================================
.idea/
# .vscode/ — intentionally NOT ignored; workspace settings may be committed
*.swp
*.swo
*~

# ============================================================
# Docker local volumes
# ============================================================
docker-compose.override.yml
docker/data/
postgres_data/
redis_data/

# ============================================================
# Claude Code / local tooling
# ============================================================
.claude/settings.local.json
.claude/projects/
.implement-plan-state.json

# ============================================================
# Open Brain — media and binary reference files
# (kept in reference/ but excluded from git tracking)
# ============================================================
*.docx
*.jpg
*.jpeg
*.png
*.gif
*.backup-*.md

# ============================================================
# Temporary session / working files
# ============================================================
temp_*.md
working-docs/
