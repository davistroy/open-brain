# Open Brain — Environment Configuration
# All secrets are stored in Bitwarden Secrets Manager
# Retrieve with: bws secret get <secret-id>
# See CLAUDE.md for the secrets management policy

# ============================================================
# DATABASE (dev defaults — non-sensitive, matches docker-compose.yml)
# ============================================================
POSTGRES_URL=postgresql://openbrain:openbrain_dev@localhost:5432/openbrain

# ============================================================
# REDIS
# ============================================================
REDIS_URL=redis://localhost:6379

# ============================================================
# LiteLLM (AI Gateway — retrieve from Bitwarden)
# ============================================================
LITELLM_URL=https://llm.k4jda.net
LITELLM_API_KEY=get-from-bitwarden

# ============================================================
# SLACK (retrieve from Bitwarden)
# ============================================================
SLACK_BOT_TOKEN=get-from-bitwarden
SLACK_APP_TOKEN=get-from-bitwarden
# Note: SLACK_SIGNING_SECRET is NOT needed for Socket Mode (only for HTTP webhooks)

# Slack User Token — required for channel cleanup (F35)
# This is an xoxp-... user token (NOT bot token) with scopes: channels:history, chat:write
# Bot tokens can only delete messages the bot sent; user tokens can delete any message.
# Create in Slack app config under "User Token Scopes", store in Bitwarden: dev/open-brain/slack-user-token
SLACK_USER_TOKEN=get-from-bitwarden

# ============================================================
# AI MODEL ALIASES (configured on llm.k4jda.net)
# ============================================================
AI_MODEL_FAST=fast
AI_MODEL_SYNTHESIS=synthesis
AI_MODEL_GOVERNANCE=governance
AI_MODEL_INTENT=intent
AI_EMBEDDING_MODEL=spark-qwen3-embedding-4b

# ============================================================
# CORE API
# ============================================================
PORT=3000
NODE_ENV=development
LOG_LEVEL=info

# ============================================================
# ADMIN API (protects destructive endpoints: reset-data, config/reload)
# Falls back to MCP_BEARER_TOKEN if not set. Fail-closed: rejects all if neither is set.
# ============================================================
ADMIN_API_KEY=get-from-bitwarden

# ============================================================
# MCP
# ============================================================
MCP_BEARER_TOKEN=get-from-bitwarden
